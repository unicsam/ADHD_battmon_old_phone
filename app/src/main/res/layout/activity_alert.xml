<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:cardPreventCornerOverlap="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ImageView
                android:id="@+id/batteryIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_warning_red" />

            <TextView
                android:id="@+id/alertTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Low Battery"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/batteryLevelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your battery is low."
                android:textAlignment="center"
                android:textColor="#6b7280"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Please connect a charger."
                android:textAlignment="center"
                android:textColor="#6b7280"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/okButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:backgroundTint="#f9fafb"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="OK"
                android:textAllCaps="true"
                android:textColor="#3b82f6"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:rippleColor="#20000000" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
